DB_POOL_MAX=10

# Auth.js (NextAuth v5)
AUTH_SECRET=your-random-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Analytics dashboard (protege l'acces a GET /api/analytics/dashboard)
# ANALYTICS_SECRET=your-secret-here
